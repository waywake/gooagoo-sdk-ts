{
  "name": "@waywake/gooagoo-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Gooagoo Open Platform bill import API.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run clean && bun build src/index.ts --target node --format esm --outfile dist/index.js && bun build src/index.ts --target node --format cjs --outfile dist/index.cjs && tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun test && bun run build"
  },
  "keywords": [
    "gooagoo",
    "sdk",
    "open",
    "bill"
  ],
  "author": "WayWake",
  "license": "MIT",
  "homepage": "https://github.com/waywake/gooagoo-sdk-ts#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/waywake/gooagoo-sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/waywake/gooagoo-sdk-ts/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  }
}
